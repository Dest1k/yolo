<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- YOLO Version -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Версия YOLO" android:textColor="@color/text_secondary" android:textSize="13sp"/>
        <RadioGroup android:id="@+id/rgVersion"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <RadioButton android:id="@+id/rbV5"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="v5/v6/v7 (якорь)"
                android:textColor="@color/text_primary" android:buttonTint="@color/accent"/>
            <RadioButton android:id="@+id/rbV8"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="v8/v9/v10/v11 (без якорь)"
                android:textColor="@color/text_primary" android:buttonTint="@color/accent"
                android:layout_marginStart="16dp"/>
        </RadioGroup>

        <!-- Input size -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Размер входа (px)" android:textColor="@color/text_secondary" android:textSize="13sp"/>
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etInputSize"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="number" android:textColor="@color/text_primary"
            android:background="@drawable/bg_field"
            android:padding="10dp" android:layout_marginBottom="16dp"/>

        <!-- Num classes -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Количество классов" android:textColor="@color/text_secondary" android:textSize="13sp"/>
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNumClasses"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="number" android:textColor="@color/text_primary"
            android:background="@drawable/bg_field"
            android:padding="10dp" android:layout_marginBottom="16dp"/>

        <!-- Confidence threshold -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Confidence threshold"
                android:textColor="@color/text_secondary" android:textSize="13sp"/>
            <TextView android:id="@+id/tvConfVal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/accent" android:textStyle="bold"/>
        </LinearLayout>
        <SeekBar android:id="@+id/seekConf"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="100" android:progressTint="@color/accent"
            android:layout_marginBottom="16dp"/>

        <!-- NMS threshold -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="NMS threshold"
                android:textColor="@color/text_secondary" android:textSize="13sp"/>
            <TextView android:id="@+id/tvNmsVal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/accent" android:textStyle="bold"/>
        </LinearLayout>
        <SeekBar android:id="@+id/seekNms"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="100" android:progressTint="@color/accent"
            android:layout_marginBottom="16dp"/>

        <!-- Threads -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="CPU потоки"
                android:textColor="@color/text_secondary" android:textSize="13sp"/>
            <TextView android:id="@+id/tvThreadsVal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/accent" android:textStyle="bold"/>
        </LinearLayout>
        <SeekBar android:id="@+id/seekThreads"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:progressTint="@color/accent"
            android:layout_marginBottom="16dp"/>

        <!-- GPU -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Использовать GPU (Vulkan)"
                android:textColor="@color/text_primary"/>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchGpu"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:thumbTint="@color/accent"/>
        </LinearLayout>

        <!-- Output names -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Имена выходных слоёв NCNN" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:layout_marginBottom="4dp"/>
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etOut0"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="output0 (v8: output0, v5: output)"
            android:textColor="@color/text_primary" android:background="@drawable/bg_field"
            android:padding="10dp" android:layout_marginBottom="8dp"/>
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etOut1"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="output1 (v5 only)"
            android:textColor="@color/text_primary" android:background="@drawable/bg_field"
            android:padding="10dp" android:layout_marginBottom="8dp"/>
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etOut2"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="output2 (v5 only)"
            android:textColor="@color/text_primary" android:background="@drawable/bg_field"
            android:padding="10dp" android:layout_marginBottom="16dp"/>

        <!-- Class names -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Имена классов (.txt, один пер строке)" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:layout_marginBottom="4dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <TextView android:id="@+id/tvClassNames"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/text_primary"
                android:textSize="13sp"/>
            <Button android:id="@+id/btnLoadNames"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Загрузить"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/accent"/>
        </LinearLayout>

        <Button android:id="@+id/btnSave"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Сохранить"
            android:backgroundTint="@color/accent"
            android:textColor="@color/bg_dark"
            android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>
