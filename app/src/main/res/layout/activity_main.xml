<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="YOLO NCNN Detector"
            android:textSize="26sp"
            android:textColor="@color/accent"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- .param -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Model .param" android:textColor="@color/text_secondary" android:textSize="13sp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:id="@+id/tvParamFile"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Не выбран" android:textColor="@color/text_primary"
                android:background="@drawable/bg_field" android:padding="10dp"
                android:singleLine="true" android:ellipsize="start"/>
            <Button android:id="@+id/btnSelectParam"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Обзор" android:layout_marginStart="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/accent"/>
        </LinearLayout>

        <!-- .bin -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Model .bin" android:textColor="@color/text_secondary" android:textSize="13sp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="20dp">
            <TextView android:id="@+id/tvBinFile"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Не выбран" android:textColor="@color/text_primary"
                android:background="@drawable/bg_field" android:padding="10dp"
                android:singleLine="true" android:ellipsize="start"/>
            <Button android:id="@+id/btnSelectBin"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Обзор" android:layout_marginStart="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/accent"/>
        </LinearLayout>

        <!-- Summary card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Параметры" android:textColor="@color/accent"
                    android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvSummary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" android:fontFamily="monospace"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Detect outputs button -->
        <Button android:id="@+id/btnDetectOutputs"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="🔍 Определить выходы модели"
            android:enabled="false"
            android:layout_marginBottom="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/accent"/>

        <Button android:id="@+id/btnSettings"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Настройки модели"
            android:layout_marginBottom="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/accent"/>

        <Button android:id="@+id/btnStartCamera"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="Запустить камеру"
            android:enabled="false"
            android:backgroundTint="@color/accent"
            android:textColor="@color/bg_dark"
            android:textStyle="bold" android:textSize="16sp"/>
    </LinearLayout>
</ScrollView>
